# 此文件仅作为 Typesense 本地开发/部署示例。
# 生产环境请替换为专用强口令，并与应用 .env 中的 TYPESENSE_API_KEY 保持一致。
TYPESENSE_API_KEY=your-typesense-api-key-here

# 可选：浏览器公开搜索（InstantSearch）
TYPESENSE_PUBLIC_SEARCH_HOST=http://127.0.0.1:8108
TYPESENSE_PUBLIC_SEARCH_INDEX=npan_items
TYPESENSE_PUBLIC_SEARCH_API_KEY=your-typesense-search-only-key-here
